                {{each list.show as data}}
                {{if $index < num(data.block, 'vod')}}
                    <li class="leo-list-item-s">
                        <div class="leo-list-item-pic leo-list-item-s-pic">
                            <a href="{{data.url}}" title="{{data.title}}" onclick="Mucho.Plug.Loading()">
                                <img src="/asset/img/blazy.png" data-original="{{data.img}}" class="leo-list-item-thumb bimg" alt="{{data.title}}">
                                <div class="leo-list-item-tips leo-bg-color-{{data.type}}">{{if data.score != ''}}{{data.score}}{{else}}{{data.remark}}{{/if}}</div>
                            </a>
                        </div>
                        <div class="leo-list-item-s-txt">
                            <span class="leo-list-item-title leo-ellipsis">
                                <a href="{{data.url}}" title="{{data.title}}">{{data.title}}</a>
                            </span>
                            <span class="leo-list-item-title-s leo-ellipsis">{{data.years}}</span>
                            <span class="leo-list-item-title-s leo-ellipsis">{{data.areas}}</span>
                            <span class="leo-list-item-title-s leo-ellipsis">{{data.actors}}</span>
                            <span class="leo-list-item-title-s leo-ellipsis-s">{{data.cont}}</span>
                            <a class="leo-list-item-btn-s leo-bg-color-{{data.type}}" href="{{data.url}}" title="{{data.title}}"  onclick="Mucho.Plug.Loading()" style="padding: 4px 14px;font-size: 1.3rem;">立即播放</a>
                        </div>
                    </li>
                {{/if}} 
                {{/each}}
                </ul>
            </div>
        </div>
        {{/if}} 
    {{/each}} 
    </script>



